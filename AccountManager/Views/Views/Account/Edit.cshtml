@model AccountManager.Models.Account
@{
    ViewData["Title"] = $"Edit – {Model.AccountName}";
}

<div class="page-header">
    <h1>✏️ Edit Account</h1>
    <nav class="top-nav"><a href="@Url.Action("Index")">← Back to List</a></nav>
</div>

<section class="card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="form-row">
            <label asp-for="AccountName">Account Name</label>
            <input asp-for="AccountName" class="form-control" required />
            <span asp-validation-for="AccountName" class="validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" type="email" class="form-control" required />
            <span asp-validation-for="Email" class="validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Contact">Contact <small>(optional)</small></label>
            <input asp-for="Contact" class="form-control" placeholder="e.g. +1-555-000-0000" />
            <span asp-validation-for="Contact" class="validation-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Save</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
