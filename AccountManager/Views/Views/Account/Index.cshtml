@model IEnumerable<AccountManager.Models.Account>
@{
    ViewData["Title"] = "Account Manager – Import & List";
}

<div class="page-header">
    <h1>📋 Account Manager</h1>
    <nav class="top-nav">
        <a href="@Url.Action("Find")">🔍 Find Account</a>
        <a href="@Url.Action("Logs")">📄 View Logs</a>
    </nav>
</div>

@if (TempData["ImportResult"] != null)
{
    <div class="alert alert-success">✅ @TempData["ImportResult"]</div>
}
@if (TempData["ImportErrors"] != null)
{
    <div class="alert alert-error">⚠️ Row errors: @TempData["ImportErrors"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error">❌ @TempData["Error"]</div>
}

<!-- Import Form -->
<section class="card">
    <h2>Import CSV</h2>
    <form asp-action="Import" method="post">
        @Html.AntiForgeryToken()
        <div class="form-row">
            <label for="csvFilePath">CSV File Path</label>
            <input type="text"
                   id="csvFilePath"
                   name="csvFilePath"
                   class="form-control"
                   value="@ViewBag.DefaultCsvPath"
                   placeholder="e.g. C:\data\accounts.csv or /app/data/accounts.csv"
                   required />
        </div>
        <button type="submit" class="btn btn-primary">⬆ Import</button>
    </form>
</section>

<!-- Account Table -->
<section class="card">
    <h2>All Accounts <span class="badge">@Model.Count()</span></h2>
    @if (!Model.Any())
    {
        <p class="empty">No accounts yet. Import a CSV file above.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Account Name</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var account in Model)
                {
                    <tr>
                        <td>@account.Id</td>
                        <td><strong>@account.AccountName</strong></td>
                        <td><a href="mailto:@account.Email">@account.Email</a></td>
                        <td>@(account.Contact ?? "—")</td>
                        <td class="date">@account.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="date">@account.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a href="@Url.Action("Details", new { id = account.Id })" class="btn-sm btn-info">View</a>
                            <a href="@Url.Action("Edit", new { id = account.Id })"    class="btn-sm btn-edit">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<!-- Log paths info -->
<section class="card log-paths">
    <h2>Log File Locations</h2>
    <table class="meta-table">
        <tr><td>✅ Success Log</td><td><code>@ViewBag.SuccessLogPath</code></td></tr>
        <tr><td>❌ Error Log</td><td><code>@ViewBag.ErrorLogPath</code></td></tr>
        <tr><td>🔄 Upserted Contact Log</td><td><code>@ViewBag.UpsertLogPath</code></td></tr>
    </table>
</section>
