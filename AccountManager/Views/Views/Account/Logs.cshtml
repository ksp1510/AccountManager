@{
    ViewData["Title"] = "Application Logs";
}

<div class="page-header">
    <h1>📄 Application Logs</h1>
    <nav class="top-nav"><a href="@Url.Action("Index")">← Back to List</a></nav>
</div>

<section class="card log-card">
    <h2>✅ Success Log <small>(last 100 entries, newest first)</small></h2>
    <pre class="log-output log-success">@ViewBag.SuccessLog</pre>
</section>

<section class="card log-card">
    <h2>❌ Error Log <small>(last 100 entries, newest first)</small></h2>
    <pre class="log-output log-error">@ViewBag.ErrorLog</pre>
</section>

<section class="card log-card">
    <h2>🔄 Upserted Contact Log <small>(last 100 entries, newest first)</small></h2>
    <pre class="log-output log-upsert">@ViewBag.UpsertLog</pre>
</section>
