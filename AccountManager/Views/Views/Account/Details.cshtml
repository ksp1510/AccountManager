@model AccountManager.Models.Account
@{
    ViewData["Title"] = $"Details – {Model.AccountName}";
}

<div class="page-header">
    <h1>📌 Account Details</h1>
    <nav class="top-nav"><a href="@Url.Action("Index")">← Back to List</a></nav>
</div>

<section class="card detail-card">
    <dl>
        <dt>ID</dt>              <dd>@Model.Id</dd>
        <dt>Account Name</dt>   <dd><strong>@Model.AccountName</strong></dd>
        <dt>Email</dt>          <dd><a href="mailto:@Model.Email">@Model.Email</a></dd>
        <dt>Contact</dt>        <dd>@(Model.Contact ?? "—")</dd>
        <dt>Created At</dt>     <dd>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
        <dt>Updated At</dt>     <dd>@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
    </dl>
    <div class="form-actions">
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">✏️ Edit</a>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Back</a>
    </div>
</section>
